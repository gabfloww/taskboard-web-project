{
  "version": 2,
  "buildCommand": "npm run setup:frontend && cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/api/index.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/$1"
    },
    {
      "src": "/",
      "dest": "frontend/dist/index.html"
    }
  ]
}
